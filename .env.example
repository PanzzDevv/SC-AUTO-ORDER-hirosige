# ================================
# PANZZSTORE - BOT CONFIGURATION
# ================================

# Telegram Bot
STORE_NAME=NamaTokoMu
ADMIN_USERNAME=usernameadmin
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_FROM_BOTFATHER
ADMIN_TELEGRAM_ID=YOUR_ADMIN_TELEGRAM_ID

# Pakasir Payment Gateway
PAKASIR_API_KEY=YOUR_PAKASIR_API_KEY
PAKASIR_SLUG=YOUR_PAKASIR_SLUG

# Server
PORT=3000
BASE_URL=https://your-domain.com

# Firebase
# Letakkan file serviceAccountKey.json (dari Firebase Console) di folder utama (satu folder dengan file .env ini).
# File .env ini tidak butuh diisi key Firebase manual lagi karena sistem otomatis membaca serviceAccountKey.json.

# Admin Dashboard
# (Tidak ada Web Dashboard lagi, fitur Admin 100% dipindahkan ke Telegram Mini App)
ADMIN_SECRET_KEY=YOUR_SECRET_KEYsecret_jwt_key_2024

# ─── GOOGLE DRIVE STORAGE ────────────────────────────────────────────────────
# Akun-akun TikTok sekarang disimpan di Google Drive agar aman jika VPS suspend.
#
# Cara setup:
# 1. Buka Google Cloud Console → Enable Google Drive API
# 2. Buat Service Account → download JSON key-nya
# 3. Buat folder di Google Drive → share ke email Service Account (akses Editor)
# 4. Copy Folder ID dari URL Drive: https://drive.google.com/drive/folders/FOLDER_ID_INI
# 5. Letakkan file JSON Service Account di root project dengan nama: googleServiceAccount.json
#    ATAU isi env GOOGLE_SERVICE_ACCOUNT_KEY dengan isi JSON-nya dalam 1 baris

# ID folder Google Drive tempat file akun disimpan (WAJIB)
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID

# (Opsional) Path ke file JSON Service Account jika bukan nama default
# Default: googleServiceAccount.json di root project
# GOOGLE_SERVICE_ACCOUNT_PATH=./googleServiceAccount.json

# (Opsional) Alternatif: isi JSON Service Account langsung sebagai string 1 baris
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
